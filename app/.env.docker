# =============================================================================
# Docker Mühit Dəyişənləri — Laravel DDD E-Commerce
# =============================================================================
#
# Bu fayl Docker mühitində Laravel-in istifadə edəcəyi parametrləri saxlayır.
# Docker Compose ilə işlədəndə bu faylı .env olaraq kopyalayın:
#   cp .env.docker .env
#
# Servis adları (mysql, redis, rabbitmq, mailpit) Docker Compose şəbəkəsində
# avtomatik DNS adları kimi həll olunur. Yəni "mysql" yazdıqda Docker bunu
# MySQL konteynerinin IP ünvanına çevirir.
# =============================================================================

APP_NAME="DDD E-Commerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# -------------------------------------------------------
# Verilənlər bazası əlaqələri (Database Connections)
# -------------------------------------------------------
# Hər bounded context öz verilənlər bazasına qoşulur.
# DB_HOST=mysql — Docker Compose-dakı MySQL servisinin adıdır.
# Docker daxili DNS vasitəsilə bu adı MySQL konteynerinin IP-sinə çevirir.

# Standart Laravel əlaqəsi — istifadəçi konteksti üçün
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=user_db
DB_USERNAME=laravel
DB_PASSWORD=secret

# Məhsul konteksti üçün verilənlər bazası əlaqəsi
DB_PRODUCT_HOST=mysql
DB_PRODUCT_PORT=3306
DB_PRODUCT_DATABASE=product_db
DB_PRODUCT_USERNAME=laravel
DB_PRODUCT_PASSWORD=secret

# Sifariş konteksti üçün verilənlər bazası əlaqəsi
DB_ORDER_HOST=mysql
DB_ORDER_PORT=3306
DB_ORDER_DATABASE=order_db
DB_ORDER_USERNAME=laravel
DB_ORDER_PASSWORD=secret

# Ödəniş konteksti üçün verilənlər bazası əlaqəsi
DB_PAYMENT_HOST=mysql
DB_PAYMENT_PORT=3306
DB_PAYMENT_DATABASE=payment_db
DB_PAYMENT_USERNAME=laravel
DB_PAYMENT_PASSWORD=secret

# -------------------------------------------------------
# RabbitMQ — Mesaj brokeri
# -------------------------------------------------------
# Asinxron servislərarası əlaqə üçün istifadə olunur.
# Məsələn: sifariş yaradılanda ödəniş servisinə mesaj göndərilir.
# RABBITMQ_HOST=rabbitmq — Docker Compose-dakı RabbitMQ servisinin adıdır.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# -------------------------------------------------------
# Redis — Keş və növbə
# -------------------------------------------------------
# REDIS_HOST=redis — Docker Compose-dakı Redis servisinin adıdır.
# Redis həm keşləmə, həm növbə, həm də sessiya üçün istifadə olunur.
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# -------------------------------------------------------
# Keş və sessiya
# -------------------------------------------------------
# "redis" seçilir çünki fayl əsaslı keş konteynerlərdə etibarlı deyil
# (konteyner yenidən başlayanda fayl keşi itir)
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# -------------------------------------------------------
# Növbə (Queue)
# -------------------------------------------------------
# Laravel job-ları Redis növbəsində saxlanılır və icra olunur.
# İstehsal mühitində RabbitMQ istifadə etmək daha yaxşıdır,
# amma inkişaf mühitində Redis kifayət edir.
QUEUE_CONNECTION=redis

# -------------------------------------------------------
# E-poçt — Mailpit
# -------------------------------------------------------
# MAIL_HOST=mailpit — Docker Compose-dakı Mailpit servisinin adıdır.
# Mailpit göndərilən e-poçtları tutur və localhost:8025-də göstərir.
# Həqiqi e-poçt göndərilmir — yalnız test üçündür.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# Log və digər parametrlər
# -------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug
BROADCAST_DRIVER=log
